# ==============================
# Variables de entorno - ucaldas-auth
# Copia este archivo como .env y reemplaza con tus datos
# ==============================

# Google OAuth (si usas integración directa)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_EXPO=tu_client_id_expo.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=tu_client_id_web.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=tu_client_id_android.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=tu_client_id_ios.apps.googleusercontent.com

# Dominio institucional permitido
EXPO_PUBLIC_ALLOWED_DOMAIN=ucaldas.edu.co

# Auth0
EXPO_PUBLIC_AUTH0_DOMAIN=dev-tu-tenant.us.auth0.com
EXPO_PUBLIC_AUTH0_CLIENT_ID=tu_client_id_auth0
EXPO_PUBLIC_AUTH0_CONNECTION=google-oauth2

# Opcional (si proteges API en Auth0)
# EXPO_PUBLIC_AUTH0_AUDIENCE=https://tu-api-identifier
